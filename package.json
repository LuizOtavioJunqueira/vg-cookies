{
  "name": "vg-cookies",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx --env-file=.env prisma/seed.ts",
    "db:setup": "prisma db push && tsx --env-file=.env prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.9.1",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.6.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.16.0",
    "next": "15.5.20",
    "next-auth": "5.0.0-beta.29",
    "pix-utils": "^2.8.2",
    "qrcode": "^1.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "ws": "^8.21.0",
    "zod": "^3.25.56",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^22.15.30",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@types/ws": "^8.18.1",
    "eslint": "^9.28.0",
    "eslint-config-next": "15.5.20",
    "postcss": "^8.5.4",
    "prisma": "^6.9.0",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
